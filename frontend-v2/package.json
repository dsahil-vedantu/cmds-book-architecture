{
  "name": "v-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "V-Studio — Vedantu's ops-facing UI layer for the CMDS content extraction service",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:api": "openapi-typescript ${VITE_API_BASE:-http://127.0.0.1:8000}/openapi.json -o src/api/generated.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-oauth/google": "^0.12.1",
    "@tanstack/react-query": "^5.100.14",
    "katex": "^0.16.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
